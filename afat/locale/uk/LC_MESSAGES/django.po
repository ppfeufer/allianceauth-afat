#: afat/views/fatlinks.py:190
msgid "<h4>Success!</h4><p>Clickable FAT link created!</p><p>Make sure to give your fleet members the link to click so that they get credit for this fleet.</p>"
msgstr "<h4>Успіх!</h4><p>Створено FAT-посилання!</p><p>Переконайтеся, що ваші члени флоту перейшли за посиланням, щоб отримати відзнаку за цей флот.</p>"

#: afat/views/fatlinks.py:206
msgid "<h4>Error!</h4><p>Something went wrong when attempting to submit your clickable FAT link.</p>"
msgstr "<h4>Помилка!</h4><p>Щось пішло не так, коли спробували відправити ваше FAT-посилання.</p>"

#: afat/views/fatlinks.py:219
msgid "<h4>Warning!</h4><p>You must fill out the form on the \"Add FAT link\" page to create a clickable FAT link</p>"
msgstr "<h4>Попередження!</h4><p>Вам слід заповнити форму на сторінці \"Додати FAT-посилання\", щоб створити його</p>"

#: afat/views/fatlinks.py:262
msgid "<h4>Warning!</h4><p>To use the ESI function, you need to be in fleet and you need to be the fleet boss! You can create a clickable FAT link and share it, if you like.</p>"
msgstr "<h4>Попередження!</h4><p>Щоб використовувати функцію ESI, вам слід бути у флоті і бути босом флоту! Ви можете створити FAT-посилання для вашого персонажа і поділитися ним.</p>"

#: afat/views/fatlinks.py:305
#, python-brace-format
msgid "<h4>Warning!</h4><p>Fleet with ID \"{fleet_id}\" for your character {creator__character_name} has already been registered and pilots joining this fleet are automatically tracked.</p>"
msgstr "<h4>Попередження!</h4><p>Флот з ID \"{fleet_id}\" для вашого персонажа {creator__character_name} вже був зареєстрований і пілоти, що приєднуються до цього флоту, автоматично відстежуються.</p>"

#: afat/views/fatlinks.py:353
msgid "<h4>Warning!</h4><p>Not Fleet Boss! Only the fleet boss can utilize the ESI function. You can create a clickable FAT link and share it, if you like.</p>"
msgstr "<h4>Попередження!</h4><p>Не бос флоту! Лише бос флоту може використовувати функцію ESI. Ви можете створити FAT-посилання для вашого персонажа і поділитися ним.</p>"

#: afat/views/fatlinks.py:419
msgid "<h4>Success!</h4><p>FAT link Created!</p><p>FATs have been queued, they may take a few minutes to show up.</p><p>Pilots who join later will be automatically added until you close or leave the fleet in-game.</p>"
msgstr "<h4>Успіх!</h4><p>FAT-посилання створено!</p><p>FAT зареєстровано, вони можуть зайняти деякий час для появи у списку FAT.</p><p>Пілоти, які приєднуються пізніше, будуть автоматично додані, поки ви не закриєте або покинете флот у грі.</p>"

#: afat/views/fatlinks.py:461
